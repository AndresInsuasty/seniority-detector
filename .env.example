# Copia este archivo a .env y rellena tu key

# OpenAI (para gpt-4o, gpt-4-turbo)
OPENAI_API_KEY=sk-...

# Anthropic (para claude-sonnet-4-6, claude-opus-4-8)
# ANTHROPIC_API_KEY=sk-ant-...

# Modelos por defecto (opcional — si no se definen se usan los valores abajo)
# DEFAULT_ANTHROPIC_MODEL=claude-sonnet-4-6
# DEFAULT_OPENAI_MODEL=gpt-4o-mini
